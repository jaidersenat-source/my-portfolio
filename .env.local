# Variables de entorno para envío de correos
# Sustituye los valores por los reales antes de iniciar el servidor.

# Servidor SMTP (ej.: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# Puerto (ej.: 587 para TLS, 465 para SSL)
SMTP_PORT=587
# Usar conexión segura (true para 465, false para 587)
SMTP_SECURE=false

# Credenciales SMTP (tu cuenta de correo o usuario SMTP)
SMTP_USER=hbrbrshop@gmail.com
# Contraseña o app password (no pongas la contraseña real si compartes el repo)
SMTP_PASS=mzaf ifyk wtep mkqe

# Email receptor (opcional). Si no está, se usará SMTP_USER
CONTACT_TO=jaidersenat@gmail.com

# Nota: Para Gmail, habilita 2FA y crea un "App Password" en tu cuenta Google
# en lugar de usar la contraseña normal. Reinicia el servidor tras crear este archivo.
